---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "profile" | "article";
  canonical?: string;
}

const DEFAULT_TITLE = "Franklin Baca Campos — Software Engineer | Lima, Perú";
const DEFAULT_DESCRIPTION =
  "Portafolio de Franklin Baca Campos, Software Engineer en Lima, Perú. Especializado en SaaS, ERP, arquitectura modular, Laravel, React y .NET.";
const DEFAULT_IMAGE = "/hap.jpg";
const SITE_URL = "https://franklincampos.com";

const {
  title = DEFAULT_TITLE,
  description = DEFAULT_DESCRIPTION,
  image = DEFAULT_IMAGE,
  type = "profile",
  canonical,
} = Astro.props;

const canonicalUrl =
  canonical ?? new URL(Astro.url.pathname, Astro.site ?? SITE_URL).href;
const imageUrl = new URL(image, Astro.site ?? SITE_URL).href;

const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Franklin Baca Campos",
  alternateName: ["Franklin Baca", "Franklin Baca-Campos", "Franklin Campos"],
  givenName: "Franklin",
  familyName: "Baca Campos",
  jobTitle: "Ingeniero de Software · Full-Stack Developer",
  description: DEFAULT_DESCRIPTION,
  url: SITE_URL,
  image: imageUrl,
  email: "mailto:franklinbacacampos@gmail.com",
  telephone: "+51-941-225-240",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Trujillo",
    addressRegion: "La Libertad",
    addressCountry: "PE",
  },
  sameAs: [
    "https://www.linkedin.com/in/franklinbacacampos/",
    "https://github.com/breakcito",
    "https://break-dev.github.io/README/",
  ],
  knowsAbout: [
    "Software Architecture",
    "SaaS",
    "Enterprise Resource Planning",
    "Laravel",
    "React",
    "FastAPI",
    "NestJS",
    ".NET",
    "Spring Boot",
    "SQL Server",
    "PostgreSQL",
    "MySQL",
    "MongoDB",
    "DevOps",
    "CI/CD",
    "Clean Architecture",
    "Vertical Slice Architecture",
    "ETL",
    "Internet of Things",
    "Cybersecurity",
  ],
  alumniOf: {
    "@type": "CollegeOrUniversity",
    name: "Universidad Privada del Norte",
    address: {
      "@type": "PostalAddress",
      addressLocality: "Trujillo",
      addressCountry: "PE",
    },
  },
  worksFor: [
    {
      "@type": "Organization",
      name: "Fabricaciones Fabero S.A.C",
      address: {
        "@type": "PostalAddress",
        addressLocality: "Trujillo",
        addressCountry: "PE",
      },
    },
    {
      "@type": "Organization",
      name: "Consorcio Minero Black Silver S.A.C",
      address: {
        "@type": "PostalAddress",
        addressLocality: "Trujillo",
        addressCountry: "PE",
      },
    },
  ],
};

const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Franklin Baca Campos — Portafolio",
  url: SITE_URL,
  inLanguage: "es-PE",
  author: {
    "@type": "Person",
    name: "Franklin Baca Campos",
    url: SITE_URL,
  },
};
---

<!doctype html>
<html lang="es-PE" class="bg-bg-dark text-gray-200">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=5.0"
    />
    <meta name="generator" content={Astro.generator} />

    <!-- Icons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Franklin Baca Campos" />
    <meta
      name="robots"
      content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
    />
    <meta name="googlebot" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Theme / colors -->
    <meta name="theme-color" content="#050505" />
    <meta name="color-scheme" content="dark" />
    <meta name="msapplication-TileColor" content="#050505" />

    <!-- Keywords (low weight, but still useful) -->
    <meta
      name="keywords"
      content="Franklin Baca Campos, Franklin Baca, Franklin Campos, breakcito, break-dev, Ingeniero de Sistemas, Full Stack Developer, Software Architect, Trujillo, Perú, SaaS, ERP, Laravel, React, .NET, Clean Architecture, Vertical Slice, desarrollador peruano, ingeniero de software Trujillo"
    />

    <!-- Geo targeting -->
    <meta name="geo.region" content="PE-LAL" />
    <meta name="geo.placename" content="Trujillo, Perú" />
    <meta name="geo.position" content="-8.1116;-79.0287" />
    <meta name="ICBM" content="-8.1116, -79.0287" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="Franklin Baca Campos" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Franklin Baca Campos" />
    <meta property="og:locale" content="es_PE" />
    <meta property="og:locale:alternate" content="es_ES" />
    <meta property="og:locale:alternate" content="en_US" />
    {
      type === "profile" && (
        <>
          <meta property="profile:first_name" content="Franklin" />
          <meta property="profile:last_name" content="Baca Campos" />
          <meta property="profile:username" content="breakcito" />
        </>
      )
    }

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content="Franklin Baca Campos" />
    <meta name="twitter:creator" content="@break_dev" />
    <meta name="twitter:site" content="@break_dev" />

    <!-- Structured Data: Person + WebSite -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify(personJsonLd)}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(websiteJsonLd)}
    />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body
    class="relative min-h-dvh w-full selection:bg-white/20 selection:text-white antialiased"
  >
    <!-- Cine/Film Grain Overlay (Fixed & GPU optimized) -->
    <div class="grain-overlay pointer-events-none fixed inset-0 z-0"></div>

    <!-- Custom Ambient Mesh Gradients (Orbs) -->
    <div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
      <!-- 1. Indigo (Top Left) -->
      <div
        class="absolute top-[-20%] left-[-10%] h-[70vw] w-[70vw] md:h-[50vw] md:w-[50vw] rounded-full bg-indigo-600/15 blur-[120px] animate-orb-indigo"
      >
      </div>
      <!-- 2. Cyan (Bottom Left) -->
      <div
        class="absolute bottom-[-20%] left-[-10%] h-[60vw] w-[60vw] md:h-[45vw] md:w-[45vw] rounded-full bg-cyan-500/15 blur-[130px] animate-orb-cyan"
      >
      </div>
      <!-- 3. Emerald (Center) -->
      <div
        class="absolute top-[20%] left-[20%] h-[50vw] w-[50vw] md:h-[35vw] md:w-[35vw] rounded-full bg-emerald-500/10 blur-[140px] animate-orb-emerald"
      >
      </div>
      <!-- 4. Amber (Bottom Right) -->
      <div
        class="absolute bottom-[-10%] right-[-10%] h-[55vw] w-[55vw] md:h-[40vw] md:w-[40vw] rounded-full bg-amber-500/12 blur-[125px] animate-orb-amber"
      >
      </div>
      <!-- 5. Fuchsia (Top Right) -->
      <div
        class="absolute top-[-10%] right-[-10%] h-[60vw] w-[60vw] md:h-[45vw] md:w-[45vw] rounded-full bg-fuchsia-600/15 blur-[135px] animate-orb-fuchsia"
      >
      </div>
    </div>

    <!-- Main Layout Slot -->
    <slot />

    <!-- Scroll Reveal Script -->
    <script>
      // Simple Intersection Observer for entry animations
      const observerOptions = {
        root: null,
        rootMargin: "0px",
        threshold: 0.1,
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("animate-fade-up");
            entry.target.classList.remove("opacity-0");
            observer.unobserve(entry.target);
          }
        });
      }, observerOptions);

      // Observe elements after load
      window.addEventListener("DOMContentLoaded", () => {
        const scrollElements = document.querySelectorAll(".scroll-reveal");
        scrollElements.forEach((el) => {
          el.classList.add("opacity-0");
          observer.observe(el);
        });
      });
    </script>
  </body>
</html>

<style is:global>
  html,
  body {
    margin: 0;
    width: 100%;
    min-height: 100dvh;
  }
</style>
