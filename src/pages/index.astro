---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import AboutMe from "../components/AboutMe.astro";
import Experience from "../components/Experience.astro";
import ProjectsBento from "../components/ProjectsBento.astro";
import ProjectsList from "../components/ProjectsList.astro";
import Credentials from "../components/Credentials.astro";
import ContactForm from "../components/ContactForm.astro";
import Footer from "../components/Footer.astro";
---

<Layout>
  <!-- Floating Glass Navigation Island -->
  <header
    class="fixed top-6 left-1/2 -translate-x-1/2 z-40 glass-panel rounded-full px-6 py-2.5 flex items-center justify-between gap-12 max-w-2xl w-[calc(100vw-2.5rem)] shadow-[0_10px_30px_rgba(0,0,0,0.5)] transition-all duration-500 hover:border-white/15"
  >
    <a
      href="#"
      class="text-sm font-bold tracking-tight text-white hover:text-neutral-300 transition-colors font-heading shrink-0"
    >
      break<span class="text-emerald-400">.dev</span>
    </a>

    <nav class="flex items-center gap-5 md:gap-7">
      <a
        href="#sobre-mi"
        class="text-[11px] uppercase tracking-wider font-mono text-neutral-400 hover:text-white transition-colors"
        >Sobre Mí</a
      >
      <a
        href="#experiencia"
        class="text-[11px] uppercase tracking-wider font-mono text-neutral-400 hover:text-white transition-colors"
        >Experiencia</a
      >
      <a
        href="#proyectos"
        class="text-[11px] uppercase tracking-wider font-mono text-neutral-400 hover:text-white transition-colors"
        >Proyectos</a
      >
      <a
        href="#credenciales"
        class="text-[11px] uppercase tracking-wider font-mono text-neutral-400 hover:text-white transition-colors hidden md:block"
        >Credenciales</a
      >
      <a
        href="#contacto"
        class="text-[11px] uppercase tracking-wider font-mono text-neutral-400 hover:text-white transition-colors"
        >Contacto</a
      >
    </nav>
  </header>

  <!-- Main Sections Content -->
  <main class="relative z-10 pt-4">
    <Hero />
    <AboutMe />
    <Experience />
    <ProjectsBento />
    <ProjectsList />
    <Credentials />
    <ContactForm />
  </main>

  <Footer />
</Layout>
