---
import ButtonIsland from "./ui/ButtonIsland.astro";
import { Download } from "@lucide/astro";
import profileImage from "../assets/hap.jpg";
---

<section
  class="relative min-h-[90dvh] flex flex-col justify-center px-6 md:px-12 max-w-7xl mx-auto py-20 md:py-32 overflow-hidden"
>
  <!-- Subtle Background Grid/Accent -->
  <div class="absolute inset-0 -z-20 opacity-20">
    <div
      class="absolute inset-0 bg-[linear-gradient(to_right,#1f2937_1px,transparent_1px),linear-gradient(to_bottom,#1f2937_1px,transparent_1px)] bg-size-[4rem_4rem] mask-[radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)] [-webkit-mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)]"
    >
    </div>
  </div>

  <div
    class="scroll-reveal w-full flex flex-col md:flex-row items-center justify-between gap-12 lg:gap-20"
  >
    <!-- Left Column: Text & CTAs -->
    <div class="flex-1 space-y-8 max-w-3xl">
      <!-- Micro Eyebrow Tag -->
      <div
        class="inline-flex w-fit items-center gap-2 rounded-full px-3 py-1 text-[10px] uppercase tracking-[0.2em] font-medium bg-white/5 border border-white/10 text-neutral-300"
      >
        <span class="relative flex h-2 w-2">
          <span
            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"
          ></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"
          ></span>
        </span>
        Disponible para nuevos proyectos
      </div>

      <!-- Massive Heading -->
      <h1
        class="text-5xl sm:text-6xl md:text-8xl font-extrabold tracking-tight leading-[0.95] text-white"
      >
        Franklin <span
          class="text-transparent bg-clip-text bg-linear-to-r from-neutral-200 via-white to-neutral-500"
          >Baca Campos</span
        >
      </h1>

      <!-- Authentic Pragmatic Subtitle -->
      <p
        class="text-lg md:text-2xl text-neutral-300 font-light leading-relaxed max-w-2xl"
      >
        Ingeniero de Sistemas. Construyo arquitecturas modulares, legibles y de
        alto rendimiento. Mi prioridad no es la sobreingeniería, sino entender
        las necesidades reales de tu producto para programar soluciones eficaces
        y duraderas.
      </p>

      <!-- Navigation/CTAs using Island buttons -->
      <div class="flex flex-wrap gap-4 pt-4">
        <ButtonIsland href="#proyectos" variant="primary" arrow={true}>
          Explorar Proyectos
        </ButtonIsland>
        <ButtonIsland href="#sobre-mi" variant="secondary">
          Quién Soy
        </ButtonIsland>
        <a
          href="/cv"
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center gap-2 rounded-full font-medium text-sm px-6 py-3.5 bg-transparent text-neutral-300 hover:text-white transition-all duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] active:scale-[0.97] cursor-pointer outline-none select-none"
          aria-label="Descargar currículum vitae en PDF"
        >
          <Download
            class="h-4 w-4 stroke-current transition-transform duration-500 ease-fluid group-hover:-translate-y-0.5"
            strokeWidth="1.8"
          />
          <span class="font-medium tracking-wide">Descargar CV</span>
        </a>
      </div>
    </div>

    <!-- Right Column: Premium Large Portrait -->
    <div class="w-full md:w-auto shrink-0 flex justify-center md:justify-end">
      <!-- Cinematic Card Wrapper -->
      <div
        class="relative w-72 h-72 sm:w-80 sm:h-80 lg:w-96 lg:h-96 rounded-4xl p-[2px] bg-linear-to-tr from-white/5 via-white/10 to-white/30 backdrop-blur-md shadow-2xl md:rotate-2 hover:rotate-0 transition-all duration-700 group overflow-hidden"
      >
        <!-- Dark base to prevent transparency issues -->
        <div class="absolute inset-0 bg-[#0a0a0c] rounded-4xl"></div>

        <!-- The Actual Photo -->
        <img
          src={profileImage.src}
          alt="Franklin Baca Campos"
          class="relative h-full w-full object-cover rounded-4xl filter grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700 z-10 opacity-90 group-hover:opacity-100"
        />

        <!-- Inner glass reflection -->
        <div
          class="absolute inset-0 rounded-4xl ring-1 ring-inset ring-white/20 z-20 pointer-events-none"
        >
        </div>
      </div>
    </div>
  </div>
</section>
