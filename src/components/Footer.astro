---

<footer
  class="relative z-10 max-w-7xl mx-auto py-16 px-6 md:px-12 border-t border-white/5 bg-bg-dark overflow-hidden"
>
  <div
    class="flex flex-col md:flex-row justify-between items-start md:items-center gap-8"
  >
    <!-- Left side: Brand identity -->
    <div class="space-y-3">
      <div class="text-xl font-bold tracking-tight text-white font-heading">
        break<span class="text-rose-400">.dev</span>
      </div>
      <p class="text-xs text-neutral-400 max-w-xs font-light font-mono">
        <span class="italic"
          >Porque una vida sin explorar, no merece ser vivida</span
        > - Sócrates
      </p>
    </div>

    <!-- Right side: Socials and Navigation links -->
    <div class="flex flex-wrap gap-x-8 gap-y-4">
      <a
        href="#proyectos"
        class="text-xs text-neutral-400 hover:text-white transition-colors font-mono"
        >Proyectos</a
      >
      <a
        href="#sobre-mi"
        class="text-xs text-neutral-400 hover:text-white transition-colors font-mono"
        >Sobre Mí</a
      >
      <a
        href="#contacto"
        class="text-xs text-neutral-400 hover:text-white transition-colors font-mono"
        >Contacto</a
      >
      <a
        href="https://github.com/break-dev"
        target="_blank"
        rel="noopener noreferrer"
        class="text-xs text-neutral-400 hover:text-white transition-colors font-mono"
        >GitHub</a
      >
      <a
        href="https://www.linkedin.com/in/franklinbacacampos/"
        target="_blank"
        rel="noopener noreferrer"
        class="text-xs text-neutral-400 hover:text-white transition-colors font-mono"
        >LinkedIn</a
      >
    </div>
  </div>

  <!-- Bottom Divider and Credits -->
  <div
    class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mt-12 pt-8 border-t border-white/5 text-[11px] text-neutral-500 font-mono"
  >
    <div>
      © {new Date().getFullYear()} Franklin Baca Campos. Todos los derechos reservados.
    </div>
    <div class="flex items-center gap-1">
      Construido con
      <a
        href="https://astro.build"
        target="_blank"
        rel="noopener noreferrer"
        class="text-neutral-500 hover:text-neutral-400 underline">Astro</a
      >
      y
      <a
        href="https://tailwindcss.com"
        target="_blank"
        rel="noopener noreferrer"
        class="text-neutral-500 hover:text-neutral-400 underline"
        >Tailwind CSS v4</a
      >.
    </div>
  </div>
</footer>
