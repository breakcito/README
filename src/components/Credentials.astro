---
import CardDoubleBezel from "./ui/CardDoubleBezel.astro";
import { Award, ShieldCheck, Languages, Trophy, Calendar } from "@lucide/astro";

interface Certification {
  issuer: string;
  title: string;
  date: string;
  icon: "award" | "shield" | "languages";
  accent: "emerald" | "blue" | "violet";
}

interface Recognition {
  title: string;
  context: string;
  date: string;
  accent: "amber" | "rose";
}

const accentMap = {
  emerald: {
    bg: "bg-emerald-500/10",
    border: "border-emerald-500/20",
    text: "text-emerald-400",
  },
  blue: {
    bg: "bg-blue-500/10",
    border: "border-blue-500/20",
    text: "text-blue-400",
  },
  violet: {
    bg: "bg-violet-500/10",
    border: "border-violet-500/20",
    text: "text-violet-400",
  },
  amber: {
    bg: "bg-amber-500/10",
    border: "border-amber-500/20",
    text: "text-amber-400",
  },
  rose: {
    bg: "bg-rose-500/10",
    border: "border-rose-500/20",
    text: "text-rose-400",
  },
};

const certIcon = {
  award: Award,
  shield: ShieldCheck,
  languages: Languages,
};

const certifications: Certification[] = [
  {
    issuer: "Cisco Networking Academy",
    title: "Network Analyst (CCNA)",
    date: "Julio 2025",
    icon: "award",
    accent: "emerald",
  },
  {
    issuer: "WeTALK — UPC",
    title: "English Learner (B1)",
    date: "Marzo 2025",
    icon: "languages",
    accent: "violet",
  },
  {
    issuer: "Cisco Networking Academy",
    title: "Junior Cybersecurity Analyst",
    date: "Junio 2024",
    icon: "shield",
    accent: "blue",
  },
];

const recognitions: Recognition[] = [
  {
    title: "Tercio Superior",
    context: "Facultad de Ingeniería — UPN",
    date: "Julio 2024",
    accent: "amber",
  },
  {
    title: "Quinto Superior",
    context: "Facultad de Ingeniería — UPN",
    date: "Noviembre 2023",
    accent: "rose",
  },
];
---

<section
  id="credenciales"
  class="relative max-w-7xl mx-auto py-24 md:py-32 px-6 md:px-12 border-t border-white/5"
>
  <!-- Section Header -->
  <div class="max-w-3xl mb-12 md:mb-16 space-y-4 scroll-reveal">
    <span
      class="text-xs uppercase tracking-[0.2em] font-medium text-amber-400 font-mono"
      >Validación</span
    >
    <h2
      class="text-3xl md:text-5xl font-bold tracking-tight text-white leading-tight"
    >
      Certificaciones <br />
      <span
        class="text-transparent bg-clip-text bg-linear-to-r from-amber-400 via-neutral-100 to-rose-400"
        >y reconocimientos</span
      >
    </h2>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8">
    <!-- Certifications Column -->
    <div class="space-y-4 scroll-reveal">
      <div class="flex items-center gap-3 mb-2">
        <div
          class="flex h-9 w-9 items-center justify-center rounded-lg bg-white/5 border border-white/10 text-neutral-300"
        >
          <Award class="h-4 w-4 stroke-current" strokeWidth="1.5" />
        </div>
        <h3 class="text-sm uppercase tracking-wider font-mono text-neutral-400">
          Certificaciones
        </h3>
      </div>

      <div class="space-y-3">
        {
          certifications.map((cert) => {
            const Icon = certIcon[cert.icon];
            const colors = accentMap[cert.accent];
            return (
              <CardDoubleBezel padding="p-5">
                <div class="flex items-center gap-4">
                  <div
                    class={`flex h-11 w-11 shrink-0 items-center justify-center rounded-xl ${colors.bg} border ${colors.border} ${colors.text}`}
                  >
                    <Icon class="h-5 w-5 stroke-current" strokeWidth="1.5" />
                  </div>
                  <div class="flex-1 min-w-0">
                    <h4 class="text-white font-semibold text-sm tracking-tight">
                      {cert.title}
                    </h4>
                    <p class="text-xs text-neutral-400 font-light truncate">
                      {cert.issuer}
                    </p>
                  </div>
                  <div class="flex items-center gap-1.5 text-[11px] font-mono text-neutral-500 shrink-0">
                    <Calendar
                      class="h-3 w-3 stroke-current"
                      strokeWidth="1.5"
                    />
                    <span>{cert.date}</span>
                  </div>
                </div>
              </CardDoubleBezel>
            );
          })
        }
      </div>
    </div>

    <!-- Recognitions Column -->
    <div class="space-y-4 scroll-reveal">
      <div class="flex items-center gap-3 mb-2">
        <div
          class="flex h-9 w-9 items-center justify-center rounded-lg bg-white/5 border border-white/10 text-neutral-300"
        >
          <Trophy class="h-4 w-4 stroke-current" strokeWidth="1.5" />
        </div>
        <h3 class="text-sm uppercase tracking-wider font-mono text-neutral-400">
          Reconocimientos académicos
        </h3>
      </div>

      <div class="space-y-3">
        {
          recognitions.map((rec) => {
            const colors = accentMap[rec.accent];
            return (
              <CardDoubleBezel padding="p-5">
                <div class="flex items-center gap-4">
                  <div
                    class={`flex h-11 w-11 shrink-0 items-center justify-center rounded-xl ${colors.bg} border ${colors.border} ${colors.text}`}
                  >
                    <Trophy class="h-5 w-5 stroke-current" strokeWidth="1.5" />
                  </div>
                  <div class="flex-1 min-w-0">
                    <h4 class="text-white font-semibold text-sm tracking-tight">
                      {rec.title}
                    </h4>
                    <p class="text-xs text-neutral-400 font-light truncate">
                      {rec.context}
                    </p>
                  </div>
                  <div class="flex items-center gap-1.5 text-[11px] font-mono text-neutral-500 shrink-0">
                    <Calendar
                      class="h-3 w-3 stroke-current"
                      strokeWidth="1.5"
                    />
                    <span>{rec.date}</span>
                  </div>
                </div>
              </CardDoubleBezel>
            );
          })
        }
      </div>

      <!-- Education note -->
      <div class="pt-4 border-t border-white/5">
        <p class="text-[11px] font-mono uppercase tracking-wider text-neutral-500 mb-2">
          Formación
        </p>
        <p class="text-sm text-neutral-300 font-light leading-relaxed">
          Ingeniería de Sistemas Computacionales — Universidad Privada del
          Norte. <span class="text-neutral-400">En curso, 10mo ciclo (el último).</span>
        </p>
      </div>
    </div>
  </div>
</section>